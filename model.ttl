                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^([A-Z]{2}[A-Z0-9]{3}|[0-9]{13})$" ] ) ] ) ] ;
            owl:onProperty trc:stop_location ],
