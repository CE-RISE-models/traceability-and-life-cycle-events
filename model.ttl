            owl:minCardinality 0 ;
            owl:onProperty trc:facility_identifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty trc:process_step_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:transformation_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty trc:process_step ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty trc:batch_identifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                                owl:onDatatype xsd:string ;
                                owl:withRestrictions ( [ xsd:pattern "^P(?:\\d+Y)?(?:\\d+M)?(?:\\d+W)?(?:\\d+D)?(?:T(?:\\d+H)?(?:\\d+M)?(?:\\d+(?:\\.\\d+)?S)?)?$" ] ) ] ) ] ;
            owl:onProperty trc:process_duration ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:value_adding_activity_data_quality_assessments ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:process_duration_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:activity_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:quality_check_performed_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:facility_identifier_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:process_certification ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:activity_type_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty trc:activity_type_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:input_entities_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom mt:TraceabilityStatement ;
            owl:onProperty trc:value_adding_activity_metrological_traceability_statements ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:operator_identifier_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:input_entities ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty trc:value_added ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:process_description_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:batch_identifier_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:input_entities_value ] ;
    skos:definition "Transformation and processing events extending EPCIS TransformationEvent" ;
    skos:inScheme trc: .

