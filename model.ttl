    skos:definition "Root container for metrological traceability statements and supporting records" ;
    skos:exactMatch mt:metrologicalTraceability ;
    skos:inScheme mt: ;
    trc:sql_identifier "mt_root" .

<https://ce-rise-models.codeberg.page/traceability-and-life-cycle-events/.owl.ttl> a owl:Ontology ;
    rdfs:label "traceability_and_life_cycle_events" ;
    dcterms:license "https://creativecommons.org/licenses/by-nc/4.0/" ;
    dcterms:title "Traceability and Life Cycle Events Data Model" ;
    pav:version "0.1.0" ;
    skos:definition "Dynamic event-based information throughout supply chain journey for products, materials, batches, and commodities aligned with GS1 EPCIS 2.0 standard. Supports both Digital Product Passports (DPP) and Digital Material Passports (DMP)." .

trc:TraceabilityLifecycleEvents a owl:Class ;
    rdfs:label "TraceabilityLifecycleEvents" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:value_adding_activity ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:aggregation_events ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:logistics_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:LogisticsEvents ;
            owl:onProperty trc:logistics_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:ReverseLogistics ;
            owl:onProperty trc:reverse_logistics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:actor_tracking ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:SupplyChainIncidents ;
            owl:onProperty trc:supply_chain_incidents ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:OwnershipEvent ;
            owl:onProperty trc:ownership_event ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:ActorTracking ;
            owl:onProperty trc:actor_tracking ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:AggregationEvents ;
            owl:onProperty trc:aggregation_events ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:ValueAddingActivityLocation ;
            owl:onProperty trc:value_adding_activity ],
        [ a owl:Restriction ;
            owl:allValuesFrom trc:EntityHistory ;
            owl:onProperty trc:entity_history ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:supply_chain_incidents ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:ownership_event ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:reverse_logistics ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:entity_history ] ;
    skos:definition "Root container for all traceability and lifecycle events for products, materials, batches, or commodities throughout their supply chain journey" ;
    skos:inScheme trc: .

uq:UncertaintyQuantification a owl:Class ;
    rdfs:label "UncertaintyQuantification" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty uq:method_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom uq:MethodReference ;
            owl:onProperty uq:method_references ],
        [ a owl:Restriction ;
            owl:allValuesFrom uq:UncertaintyStatement ;
            owl:onProperty uq:uncertainty_statements ],
        [ a owl:Restriction ;
