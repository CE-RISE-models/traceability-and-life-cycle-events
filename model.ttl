        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:stop_duration ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:stop_timestamp_value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty trc:stop_duration_value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:stop_duration_value ],
        [ a owl:Restriction ;
