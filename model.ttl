            owl:onProperty uq:uncertainty_traceability_reference_value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty uq:uncertainty_statement_notes_value ],
        [ a owl:Restriction ;
