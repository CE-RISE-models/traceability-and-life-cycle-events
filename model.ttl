trc:actor_tracking a owl:ObjectProperty ;
    rdfs:label "actor_tracking" ;
    skos:definition "All supply chain participants and their interactions with entities (products, materials, batches, commodities)" ;
    skos:inScheme trc: .

trc:affected_entities a owl:DatatypeProperty ;
    rdfs:label "affected_entities" ;
    skos:definition "EPCs, GTINs, batch numbers, or lot identifiers of affected entities (products, materials, batches, commodities)" ;
    skos:inScheme trc: ;
    trc:owl.filler "epcis:EPCList" ;
    trc:sql_identifier "trc_incident_affected_entities" .

trc:aggregation_events a owl:ObjectProperty ;
    rdfs:label "aggregation_events" ;
    skos:definition "Packaging hierarchy operations - packing and unpacking of items into containers" ;
    skos:inScheme trc: .

trc:certification_info a owl:DatatypeProperty ;
    rdfs:label "certification_info" ;
    skos:definition "URI references to relevant certification documents or standards" ;
    skos:inScheme trc: ;
    trc:reference_type "certification" ;
    trc:references "King et al." ;
    trc:sql_identifier "trc_hist_certification_info" .

trc:certification_status a owl:DatatypeProperty ;
    rdfs:label "certification_status" ;
    skos:definition "URI references to actor certifications ISO 9001 ISO 14001 organic fair trade" ;
    skos:inScheme trc: ;
