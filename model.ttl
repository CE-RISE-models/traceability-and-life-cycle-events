            owl:onProperty trc:action_performed ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty trc:activity_timestamp ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:actor_role_value ],
