trc:IntermediateStop a owl:Class ;
    rdfs:label "IntermediateStop" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty trc:stop_timestamp_value ],
